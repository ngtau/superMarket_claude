{
  "name": "@app/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w --preserveWatchOutput & node --watch dist/main.js",
    "start": "node dist/main.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "lint": "echo \"(lint TODO)\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@app/shared": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "drizzle-orm": "^0.36.0",
    "pg": "^8.13.0",
    "zod": "^3.23.8",
    "resend": "^4.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "helmet": "^8.0.0",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/schedule": "^4.1.1",
    "@sentry/node": "^8.40.0",
    "multer": "^1.4.5-lts.1",
    "@nestjs/serve-static": "^4.0.2",
    "@aws-sdk/client-s3": "^3.699.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "@types/node": "^22.7.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "vitest": "^2.1.0",
    "@types/multer": "^1.4.12"
  }
}