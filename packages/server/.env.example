# === 数据库（D1：direct端点+pg客户端池 二选一，若用pooled端点则设 DB_USE_CLIENT_POOL=false） ===
DATABASE_URL=postgres://user:password@host:5432/apcube
DB_USE_CLIENT_POOL=true

# === JWT（D2） ===
JWT_ACCESS_SECRET=changeme
JWT_REFRESH_SECRET=changeme
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# === 自定义域（R-CAV-1） ===
API_BASE_URL=https://api.apcube.com
CLIENT_ORIGIN=https://shop.apcube.com
ADMIN_ORIGIN=https://admin.apcube.com

# === Resend（D18） ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@apcube.com

# === 加密（D11：PII列级AES-256） ===
AES_ENCRYPTION_KEY=changeme-32bytes-key

# === 监控（D6） ===
SENTRY_DSN=
GRAFANA_CLOUD_REMOTE_WRITE_URL=

# === 支付渠道商户信息占位（D15，PSP就绪前留空，门控关闭） ===
FPS_MERCHANT_ID=
PAYME_MERCHANT_ID=
ALIPAYHK_MERCHANT_ID=

PORT=3000
